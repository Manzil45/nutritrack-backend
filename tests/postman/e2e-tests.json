{
  "info": {
    "name": "NutriTrack E2E Tests",
    "description": "End-to-end user journey testing for NutriTrack",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Health check returns 200', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Status is ok', function() {",
              "  const json = pm.response.json();",
              "  pm.expect(json.status).to.eql('ok');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{BASE_URL}}/api/health"
      }
    },
    {
      "name": "2. Register User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Register berhasil → 201', function() {",
              "  pm.response.to.have.status(201);",
              "});",
              "pm.test('Response punya email dan name', function() {",
              "  const json = pm.response.json();",
              "  pm.expect(json.email).to.exist;",
              "  pm.expect(json.name).to.exist;",
              "});",
              "pm.collectionVariables.set('USER_EMAIL', pm.request.body.raw ? JSON.parse(pm.request.body.raw).email : '');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"name\": \"E2E Test User\", \"email\": \"e2etest_{{$timestamp}}@nutritrack.com\", \"password\": \"Test123456\"}"
        },
        "url": "{{BASE_URL}}/api/auth/register"
      }
    },
    {
      "name": "3. Login User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const email = pm.collectionVariables.get('USER_EMAIL') || 'e2etest@nutritrack.com';",
              "pm.collectionVariables.set('LOGIN_EMAIL', email);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login berhasil → 200', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response punya token', function() {",
              "  const json = pm.response.json();",
              "  pm.expect(json.token).to.exist;",
              "  pm.collectionVariables.set('AUTH_TOKEN', json.token);",
              "  pm.collectionVariables.set('USER_ID', json._id);",
              "});",
              "pm.test('Password tidak di-return', function() {",
              "  const json = pm.response.json();",
              "  pm.expect(json.password).to.not.exist;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"{{LOGIN_EMAIL}}\", \"password\": \"Test123456\"}"
        },
        "url": "{{BASE_URL}}/api/auth/login"
      }
    },
    {
      "name": "4. Get Profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Get profile berhasil → 200', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Profile punya goals dan preferences', function() {",
              "  const json = pm.response.json();",
              "  pm.expect(json.goals).to.exist;",
              "  pm.expect(json.preferences).to.exist;",
              "  pm.expect(json.goals.calories).to.eql(2000);",
              "});",
              "pm.test('Password tidak di-return', function() {",
              "  const json = pm.response.json();",
              "  pm.expect(json.password).to.not.exist;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{AUTH_TOKEN}}" }],
        "url": "{{BASE_URL}}/api/users/profile"
      }
    },
    {
      "name": "5. Update Profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Update profile berhasil → 200', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Goals terupdate', function() {",
              "  const json = pm.response.json();",
              "  pm.expect(json.goals.calories).to.eql(2500);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{AUTH_TOKEN}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"goals\": {\"calories\": 2500, \"protein\": 180, \"carbs\": 300, \"fat\": 70}}"
        },
        "url": "{{BASE_URL}}/api/users/profile"
      }
    },
    {
      "name": "6. Log Meal",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Log meal berhasil → 201', function() {",
              "  pm.response.to.have.status(201);",
              "});",
              "pm.test('Meal tersimpan dengan benar', function() {",
              "  const json = pm.response.json();",
              "  pm.expect(json.name).to.exist;",
              "  pm.expect(json.calories).to.exist;",
              "  pm.collectionVariables.set('MEAL_ID', json._id);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{AUTH_TOKEN}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"name\": \"Nasi Goreng\", \"calories\": 450, \"protein\": 12, \"carbs\": 65, \"fat\": 15, \"mealType\": \"lunch\"}"
        },
        "url": "{{BASE_URL}}/api/meals"
      }
    },
    {
      "name": "7. Get All Meals",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Get meals berhasil → 200', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response adalah array', function() {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.be.an('array');",
              "  pm.expect(json.length).to.be.greaterThan(0);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{AUTH_TOKEN}}" }],
        "url": "{{BASE_URL}}/api/meals"
      }
    },
    {
      "name": "8. Chat dengan Gemini AI",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Chat berhasil → 200', function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response punya text', function() {",
              "  const json = pm.response.json();",
              "  pm.expect(json.text).to.exist;",
              "  pm.expect(json.text.length).to.be.greaterThan(0);",
              "});",
              "pm.test('Response punya hasBento', function() {",
              "  const json = pm.response.json();",
              "  pm.expect(json.hasBento).to.be.a('boolean');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{AUTH_TOKEN}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"message\": \"Berapa kalori nasi goreng 1 porsi?\"}"
        },
        "url": "{{BASE_URL}}/api/chat"
      }
    },
    {
      "name": "9. Delete Meal",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Delete meal berhasil → 200', function() {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{AUTH_TOKEN}}" }],
        "url": "{{BASE_URL}}/api/meals/{{MEAL_ID}}"
      }
    },
    {
      "name": "10. Unauthorized Access Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Akses tanpa token → 401', function() {",
              "  pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{BASE_URL}}/api/meals"
      }
    }
  ],
  "variable": [
    { "key": "AUTH_TOKEN", "value": "" },
    { "key": "USER_ID", "value": "" },
    { "key": "MEAL_ID", "value": "" },
    { "key": "USER_EMAIL", "value": "" },
    { "key": "LOGIN_EMAIL", "value": "" }
  ]
}